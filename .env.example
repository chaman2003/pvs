# Local dev (MongoDB on your machine)
# MONGO_URI=mongodb://127.0.0.1:27017/pvs_promoters

# Docker Compose — use the MongoDB service hostname, NOT 127.0.0.1
MONGO_URI=mongodb://mongodb:27017/pvs_promoters

ADMIN_USERNAME=pvs-promoters
ADMIN_PASSWORD=pvs-promoters@2026
JWT_SECRET=change-this-to-a-long-random-string
NEXT_PUBLIC_SITE_URL=https://pvs-promoters.com
NODE_ENV=production
