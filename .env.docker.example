# Copy to .env for docker compose: cp .env.docker.example .env
#
# IMPORTANT: Inside Docker, 127.0.0.1 is the web container itself — not MongoDB.
# Use mongodb://mongodb:27017/pvs_promoters when running docker compose (web + mongodb).

MONGO_URI=mongodb://mongodb:27017/pvs_promoters
DATA_DIR=/app/data

ADMIN_USERNAME=pvs-promoters
ADMIN_PASSWORD=pvs-promoters@2026
JWT_SECRET=change-this-to-a-long-random-string-in-production
NEXT_PUBLIC_SITE_URL=https://pvs-promoters.com
