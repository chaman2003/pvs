# Copy to .env: cp .env.docker.example .env
# All data is stored in MongoDB Atlas — set MONGO_URI to your Atlas connection string.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pvs_promoters?appName=Cluster0

ADMIN_USERNAME=pvs-promoters
ADMIN_PASSWORD=pvs-promoters@2026
JWT_SECRET=change-this-to-a-long-random-string-in-production
NEXT_PUBLIC_SITE_URL=https://pvs-promoters.com
NODE_ENV=production
