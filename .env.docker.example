# Copy to .env for docker compose: cp .env.docker.example .env
# Use host Mongo URI when seeding from your machine:
# MONGO_URI=mongodb://127.0.0.1:27017/pvs_promoters npm run seed

ADMIN_USERNAME=pvs-promoters
ADMIN_PASSWORD=pvs-promoters@2026
JWT_SECRET=change-this-to-a-long-random-string-in-production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for admin/projects/inquiries when using MongoDB (docker compose sets this automatically)
# MONGO_URI=mongodb://mongodb:27017/pvs_promoters

# Fallback inquiry storage when MongoDB is unavailable (docker compose mounts /app/data)
# DATA_DIR=/app/data
